# ============================================
# VARIÁVEIS DE AMBIENTE — GAROA BARBEARIA
# ============================================
# Copie este arquivo para .env e preencha os valores

# Banco de dados — cole a connection string do Supabase aqui
DATABASE_URL="postgresql://postgres:[SENHA]@db.[PROJETO].supabase.co:5432/postgres"

# JWT — gere uma string aleatória longa e secreta
JWT_SECRET="sua-chave-secreta-aqui"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3001
NODE_ENV=production

# URL do frontend (para CORS) — cole a URL da Vercel depois do deploy
FRONTEND_URL="https://seu-app.vercel.app"

# Nome da barbearia (aparece na interface)
BARBEARIA_NOME="Barbearia do João"
