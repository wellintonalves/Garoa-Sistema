// ============================================
// Schema do banco de dados — Garoa Barbearia
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Enums ---

enum Papel {
  ADMIN
  BARBEIRO
  CLIENTE
}

enum StatusAgendamento {
  AGUARDANDO
  CONFIRMADO
  CONCLUIDO
  CANCELADO
}

enum TipoLancamento {
  ENTRADA
  SAIDA
}

enum FormaPagamento {
  DINHEIRO
  PIX
  CARTAO_DEBITO
  CARTAO_CREDITO
}

enum TipoRecompensa {
  SERVICO_GRATIS
  DESCONTO_PERCENTUAL
  DESCONTO_REAIS
}

enum RemetenteMensagem {
  CLIENTE
  ADMIN
}

// --- Modelos ---

enum StatusAprovacao {
  PENDENTE
  APROVADO
  REJEITADO
}

enum StatusResgate {
  PENDENTE
  CONFIRMADO
  CANCELADO
}

model Barbearia {
  id                 String   @id @default(uuid())
  nome               String
  slug               String   @unique
  telefone           String?
  endereco           String?
  logo               String?
  corPrimaria        String?  @default("#FF8C00") // Laranja
  corSecundaria      String?  @default("#1A1A1A") // Escuro
  corTexto           String?  @default("#FFFFFF") // Branco
  fonte              String?  @default("Inter")
  fonteCorpo         String?  @default("Inter")
  fonteNumeros       String?  @default("DM Mono")
  horarioAbertura    String?  @default("09:00")
  horarioFechamento   String?  @default("19:00")
  temAlmoco           Boolean  @default(false)
  horarioAlmocoInicio String?  @default("12:00")
  horarioAlmocoFim    String?  @default("13:00")
  diasFuncionamento   String[] @default(["1", "2", "3", "4", "5", "6"]) // Seg a Sab
  ativo              Boolean  @default(true)
  createdAt          DateTime @default(now())

  usuarios               Usuario[]
  barbeiros              Barbeiro[]
  clientes               Cliente[]
  servicos               Servico[]
  agendamentos           Agendamento[]
  lancamentosFinanceiros LancamentoFinanceiro[]
  estoque                Estoque[]
  vendasProdutos         VendaProduto[]
  configuracoes          Configuracao[]
  clientesBarbearias     ClienteBarbearia[]
  pontosFidelidade       PontoFidelidade[]
  configuracaoFidelidade ConfiguracaoFidelidade?
  recompensas            Recompensa[]
  resgatesRecompensa     ResgateRecompensa[]
  chatMensagens          ChatMensagem[]
  indicacoes             Indicacao[]
  avaliacoes             Avaliacao[]

  @@map("barbearias")
}

model Usuario {
  id                String   @id @default(uuid())
  nome              String
  email             String
  senha             String
  papel             Papel    @default(CLIENTE)
  barbeariaId       String?
  emailVerificado   Boolean  @default(false)
  codigoVerificacao String?
  codigoExpiracao   DateTime?
  createdAt         DateTime @default(now())

  barbearia Barbearia? @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  barbeiro  Barbeiro?
  cliente   Cliente?

  @@unique([email, barbeariaId])
  @@map("usuarios")
}

model Barbeiro {
  id              String   @id @default(uuid())
  usuarioId       String   @unique
  barbeariaId     String?
  foto            String?
  especialidades  String[]
  comissaoPercent Float    @default(50)
  cor             String?  @default("#F97316") // Laranja
  ativo           Boolean  @default(true)
  trabalhandoAgora Boolean @default(false)
  telefone        String?
  horariosTrabalho Json?
  avaliacaoMedia  Float?   @default(5.0)

  barbearia       Barbearia?             @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  usuario         Usuario                @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  agendamentos    Agendamento[]
  lancamentos     LancamentoFinanceiro[]
  aprovacoes      AprovacaoEdicao[]
  bloqueiosAgenda BloqueioAgenda[]
  avaliacoes      Avaliacao[]

  @@index([barbeariaId])
  @@map("barbeiros")
}

model BloqueioAgenda {
  id          String   @id @default(uuid())
  barbeiroId  String
  dataInicio  DateTime
  dataFim     DateTime
  motivo      String?
  createdAt   DateTime @default(now())

  barbeiro    Barbeiro @relation(fields: [barbeiroId], references: [id], onDelete: Cascade)

  @@index([barbeiroId])
  @@index([dataInicio, dataFim])
  @@map("bloqueios_agenda")
}

model Cliente {
  id               String    @id @default(uuid())
  usuarioId        String    @unique
  barbeariaId      String?
  telefone         String?
  dataNascimento   DateTime?
  observacoes      String?
  codigoIndicacao  String?   @unique

  barbearia          Barbearia?          @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  usuario            Usuario             @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  agendamentos       Agendamento[]
  clientesBarbearias ClienteBarbearia[]
  pontosFidelidade   PontoFidelidade[]
  resgatesRecompensa ResgateRecompensa[]
  chatMensagens      ChatMensagem[]
  indicacoesFeitas   Indicacao[]         @relation("Indicador")
  indicacaoRecebida  Indicacao[]         @relation("Indicado")
  avaliacoes         Avaliacao[]

  @@index([barbeariaId])
  @@map("clientes")
}

model ClienteBarbearia {
  id          String   @id @default(uuid())
  clienteId   String
  barbeariaId String?
  conectadoEm DateTime @default(now())

  cliente   Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  barbearia Barbearia? @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)

  @@unique([clienteId, barbeariaId])
  @@map("clientes_barbearias")
}

model PontoFidelidade {
  id            String   @id @default(uuid())
  clienteId     String
  barbeariaId   String?
  agendamentoId String?  @unique
  pontos        Int
  descricao     String
  data          DateTime @default(now())

  cliente   Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  barbearia Barbearia? @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)

  @@map("pontos_fidelidade")
}

model Servico {
  id              String  @id @default(uuid())
  barbeariaId     String?
  nome            String
  descricao       String?
  preco           Decimal @db.Decimal(10, 2)
  duracaoMinutos  Int
  comissaoPercent Float   @default(50)
  cor             String? @default("#22C55E") // Verde
  ativo           Boolean @default(true)

  barbearia    Barbearia?             @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  agendamentos Agendamento[]
  lancamentos  LancamentoFinanceiro[]
  recompensas  Recompensa[]

  @@map("servicos")
}

model Agendamento {
  id           String             @id @default(uuid())
  barbeariaId  String?
  clienteId    String
  barbeiroId   String
  servicoId    String
  servicosIds  String[]           @default([])
  dataHora     DateTime
  status       StatusAgendamento  @default(AGUARDANDO)
  observacoes  String?
  valorCobrado Decimal            @db.Decimal(10, 2)
  origem       String             @default("SISTEMA")
  createdAt    DateTime           @default(now())

  barbearia Barbearia? @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  cliente  Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  barbeiro Barbeiro @relation(fields: [barbeiroId], references: [id], onDelete: Cascade)
  servico  Servico  @relation(fields: [servicoId], references: [id], onDelete: Cascade)

  lancamentos LancamentoFinanceiro[]
  avaliacao   Avaliacao?

  @@index([barbeariaId, dataHora])
  @@index([clienteId])
  @@index([barbeiroId])
  @@map("agendamentos")
}

model LancamentoFinanceiro {
  id             String         @id @default(uuid())
  barbeariaId    String?
  tipo           TipoLancamento
  categoria      String
  descricao      String?
  valor          Decimal        @db.Decimal(10, 2)
  formaPagamento FormaPagamento
  agendamentoId  String?
  
  barbeiroId     String?
  servicoId      String?
  valorComissao  Decimal?       @db.Decimal(10, 2)
  valorLiquido   Decimal?       @db.Decimal(10, 2)
  
  data           DateTime
  createdAt      DateTime       @default(now())

  aprovacoes  AprovacaoEdicao[]

  barbearia   Barbearia?   @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  agendamento Agendamento? @relation(fields: [agendamentoId], references: [id], onDelete: SetNull)
  barbeiro    Barbeiro?    @relation(fields: [barbeiroId], references: [id], onDelete: SetNull)
  servico     Servico?     @relation(fields: [servicoId], references: [id], onDelete: SetNull)

  @@index([barbeariaId, data])
  @@map("lancamentos_financeiros")
}

model Estoque {
  id               String   @id @default(uuid())
  barbeariaId      String?
  nome             String
  quantidade       Int
  unidade          String
  quantidadeMinima Int      @default(5)
  custo            Decimal  @db.Decimal(10, 2)
  precoVenda       Decimal? @db.Decimal(10, 2)

  barbearia Barbearia?     @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  vendas    VendaProduto[]

  @@index([barbeariaId])
  @@map("estoque")
}

model VendaProduto {
  id             String         @id @default(uuid())
  barbeariaId    String?
  estoqueId      String?
  nomeProduto    String
  quantidade     Int
  precoVenda     Decimal        @db.Decimal(10, 2)
  custoUnitario  Decimal        @db.Decimal(10, 2)
  lucro          Decimal        @db.Decimal(10, 2)
  formaPagamento FormaPagamento
  data           DateTime       @default(now())

  barbearia Barbearia? @relation(fields: [barbeariaId], references: [id], onDelete: SetNull)
  estoque   Estoque?   @relation(fields: [estoqueId], references: [id], onDelete: SetNull)

  @@index([barbeariaId, data])
  @@map("vendas_produtos")
}

model Configuracao {
  id                    String   @id @default(uuid())
  barbeariaId           String?   @unique
  horariosFuncionamento Json?
  regrasFidelidade      Json?

  barbearia Barbearia? @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)

  @@map("configuracoes")
}

model ConfiguracaoFidelidade {
  id                     String   @id @default(uuid())
  barbeariaId            String?  @unique
  ativo                  Boolean  @default(false)
  pontosPorReal          Int      @default(0)
  pontosPorVisita        Int      @default(0)
  pontosDobroAniversario Boolean  @default(false)
  pontosPorIndicacao     Int      @default(0)
  pontosBoasVindas       Int      @default(0)
  regrasPorServico       Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  barbearia Barbearia? @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)

  @@map("configuracoes_fidelidade")
}

model Recompensa {
  id                String         @id @default(uuid())
  barbeariaId       String?
  nome              String
  tipo              TipoRecompensa
  valorDesconto     Decimal?       @db.Decimal(10, 2)
  servicoId         String?
  pontosNecessarios Int
  ativo             Boolean        @default(true)
  createdAt         DateTime       @default(now())

  barbearia Barbearia? @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  servico   Servico?   @relation(fields: [servicoId], references: [id], onDelete: SetNull)
  resgates  ResgateRecompensa[]

  @@map("recompensas")
}

model ResgateRecompensa {
  id            String        @id @default(uuid())
  clienteId     String
  recompensaId  String
  barbeariaId   String?
  pontosUsados  Int
  status        StatusResgate @default(PENDENTE)
  confirmadoPor String?
  confirmadoEm  DateTime?
  createdAt     DateTime      @default(now())

  cliente    Cliente    @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  recompensa Recompensa @relation(fields: [recompensaId], references: [id], onDelete: Cascade)
  barbearia  Barbearia? @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)

  @@map("resgates_recompensa")
}

model ChatMensagem {
  id          String             @id @default(uuid())
  barbeariaId String?
  clienteId   String
  texto       String
  remetente   RemetenteMensagem
  lida        Boolean            @default(false)
  createdAt   DateTime           @default(now())

  barbearia Barbearia? @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  cliente   Cliente    @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("chat_mensagens")
}

model Indicacao {
  id              String   @id @default(uuid())
  barbeariaId     String?
  indicadorId     String
  indicadoId      String
  pontosAwardados Boolean  @default(false)
  createdAt       DateTime @default(now())

  barbearia Barbearia? @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  indicador Cliente    @relation("Indicador", fields: [indicadorId], references: [id], onDelete: Cascade)
  indicado  Cliente    @relation("Indicado", fields: [indicadoId], references: [id], onDelete: Cascade)

  @@map("indicacoes")
}

model AprovacaoEdicao {
  id              String         @id @default(uuid())
  lancamentoId    String
  barbeiroId      String
  acao            String         // "EDITAR" ou "EXCLUIR"
  dadosNovos      Json?          // Null if acao == EXCLUIR
  status          StatusAprovacao @default(PENDENTE)
  createdAt       DateTime       @default(now())

  lancamento LancamentoFinanceiro @relation(fields: [lancamentoId], references: [id], onDelete: Cascade)
  barbeiro   Barbeiro             @relation(fields: [barbeiroId], references: [id], onDelete: Cascade)

  @@map("aprovacoes_edicao")
}

model BoasVindasConcedida {
  id          String   @id @default(uuid())
  clienteId   String
  barbeariaId String
  createdAt   DateTime @default(now())

  @@unique([clienteId, barbeariaId])
  @@map("boas_vindas_concedidas")
}

model Avaliacao {
  id            String   @id @default(uuid())
  barbeariaId   String?
  barbeiroId    String
  clienteId     String
  agendamentoId String   @unique
  nota          Int
  comentario    String?
  data          DateTime @default(now())

  barbearia   Barbearia?  @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  barbeiro    Barbeiro    @relation(fields: [barbeiroId], references: [id], onDelete: Cascade)
  cliente     Cliente     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  agendamento Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)

  @@index([barbeiroId])
  @@map("avaliacoes")
}
