// ============================================
// Schema do banco de dados — Garoa Barbearia
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum Papel {
  ADMIN
  BARBEIRO
  CLIENTE
}

enum StatusAgendamento {
  AGUARDANDO
  CONFIRMADO
  CONCLUIDO
  CANCELADO
}

enum TipoLancamento {
  ENTRADA
  SAIDA
}

enum FormaPagamento {
  DINHEIRO
  PIX
  CARTAO_DEBITO
  CARTAO_CREDITO
}

// --- Modelos ---

model Barbearia {
  id                 String   @id @default(uuid())
  nome               String
  slug               String   @unique
  telefone           String?
  endereco           String?
  logo               String?
  corPrimaria        String?  @default("#FF8C00") // Laranja
  horarioAbertura    String?  @default("09:00")
  horarioFechamento  String?  @default("19:00")
  diasFuncionamento  String[] @default(["1", "2", "3", "4", "5", "6"]) // Seg a Sab
  ativo              Boolean  @default(true)
  createdAt          DateTime @default(now())

  usuarios               Usuario[]
  barbeiros              Barbeiro[]
  clientes               Cliente[]
  servicos               Servico[]
  agendamentos           Agendamento[]
  lancamentosFinanceiros LancamentoFinanceiro[]
  estoque                Estoque[]
  configuracoes          Configuracao[]

  @@map("barbearias")
}

model Usuario {
  id        String   @id @default(uuid())
  nome        String
  email       String
  senha       String
  papel       Papel    @default(CLIENTE)
  barbeariaId String
  createdAt   DateTime @default(now())

  barbearia Barbearia @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  barbeiro  Barbeiro?
  cliente   Cliente?

  @@unique([email, barbeariaId])
  @@map("usuarios")
}

model Barbeiro {
  id              String   @id @default(uuid())
  usuarioId       String   @unique
  barbeariaId     String
  foto            String?
  especialidades  String[]
  comissaoPercent Float    @default(50)
  ativo           Boolean  @default(true)

  barbearia    Barbearia     @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  usuario      Usuario       @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  agendamentos Agendamento[]
  lancamentos  LancamentoFinanceiro[]

  @@map("barbeiros")
}

model Cliente {
  id             String    @id @default(uuid())
  usuarioId      String    @unique
  barbeariaId    String
  telefone       String?
  dataNascimento DateTime?
  observacoes    String?

  barbearia    Barbearia     @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  usuario      Usuario       @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  agendamentos Agendamento[]

  @@map("clientes")
}

model Servico {
  id              String  @id @default(uuid())
  barbeariaId     String
  nome            String
  descricao       String?
  preco           Decimal @db.Decimal(10, 2)
  duracaoMinutos  Int
  comissaoPercent Float   @default(50)
  ativo           Boolean @default(true)

  barbearia    Barbearia              @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  agendamentos Agendamento[]
  lancamentos  LancamentoFinanceiro[]

  @@map("servicos")
}

model Agendamento {
  id           String             @id @default(uuid())
  barbeariaId  String
  clienteId    String
  barbeiroId   String
  servicoId    String
  dataHora     DateTime
  status       StatusAgendamento  @default(AGUARDANDO)
  observacoes  String?
  valorCobrado Decimal            @db.Decimal(10, 2)
  origem       String             @default("SISTEMA")
  createdAt    DateTime           @default(now())

  barbearia Barbearia @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  cliente  Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  barbeiro Barbeiro @relation(fields: [barbeiroId], references: [id], onDelete: Cascade)
  servico  Servico  @relation(fields: [servicoId], references: [id], onDelete: Cascade)

  lancamentos LancamentoFinanceiro[]

  @@map("agendamentos")
}

model LancamentoFinanceiro {
  id             String         @id @default(uuid())
  barbeariaId    String
  tipo           TipoLancamento
  categoria      String
  descricao      String?
  valor          Decimal        @db.Decimal(10, 2)
  formaPagamento FormaPagamento
  agendamentoId  String?
  
  barbeiroId     String?
  servicoId      String?
  valorComissao  Decimal?       @db.Decimal(10, 2)
  valorLiquido   Decimal?       @db.Decimal(10, 2)
  
  data           DateTime
  createdAt      DateTime       @default(now())

  barbearia   Barbearia    @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  agendamento Agendamento? @relation(fields: [agendamentoId], references: [id], onDelete: SetNull)
  barbeiro    Barbeiro?    @relation(fields: [barbeiroId], references: [id], onDelete: SetNull)
  servico     Servico?     @relation(fields: [servicoId], references: [id], onDelete: SetNull)

  @@map("lancamentos_financeiros")
}

model Estoque {
  id               String  @id @default(uuid())
  barbeariaId      String
  nome             String
  quantidade       Int
  unidade          String
  quantidadeMinima Int     @default(5)
  custo            Decimal @db.Decimal(10, 2)

  barbearia Barbearia @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)

  @@map("estoque")
}

model Configuracao {
  id                    String   @id @default(uuid())
  barbeariaId           String   @unique
  horariosFuncionamento Json?
  regrasFidelidade      Json?

  barbearia Barbearia @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)

  @@map("configuracoes")
}
