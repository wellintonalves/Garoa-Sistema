# Banco de dados — cole a connection string do Supabase
DATABASE_URL="postgresql://postgres:[SENHA]@db.[PROJETO].supabase.co:5432/postgres"

# JWT — gere strings aleatórias longas e secretas (mínimo 24 caracteres)
JWT_SECRET="sua-chave-secreta-aqui-mude-isso"
JWT_SECRET_CLIENTE="sua-chave-secreta-cliente-aqui-mude-isso"
JWT_SECRET_BARBEIRO="sua-chave-secreta-barbeiro-aqui-mude-isso"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3001
NODE_ENV=development

# URL do frontend (CORS)
FRONTEND_URL="http://localhost:5173"

# Nome da barbearia
BARBEARIA_NOME="Barbearia do João"
